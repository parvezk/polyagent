# Copy to web/.env.local (gitignored). Production values live in Vercel.
# PostHog tracking only runs on polyagent.pro / www.polyagent.pro in production builds.

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local-dev auth bypass. When the Supabase vars above are unset the middleware fails
# CLOSED (redirects everything to /login) — EXCEPT when this is "true" AND the build is
# not production. Lets you run/build the UI without a Supabase project. Never set in prod.
AUTH_DEV_BYPASS=
