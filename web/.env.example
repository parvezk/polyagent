# Copy to web/.env.local (gitignored). Production values live in Vercel.
# PostHog tracking only runs on polyagent.pro / www.polyagent.pro in production builds.

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional dev-only escape hatch: with the Supabase vars above unset, the auth gate
# passes through automatically in dev builds. Set this to "true" to opt into that
# bypass outside a dev build. In production without it, missing Supabase vars fail closed.
# SUPABASE_AUTH_BYPASS=true
